{
    "$schema": "https://raw.githubusercontent.com/F5Networks/f5-appsvcs-extension/main/schema/latest/as3-schema.json",
    "class": "AS3",
    "action": "deploy",
    "persist": true,
    "declaration": {
        "class": "ADC",
        "schemaVersion": "3.0.0",
        "sni_routing": {
            "class": "Tenant",
            "app_sni_routing": {
                "class": "Application",
                "service": {
                    "class": "Service_TCP",
                    "virtualType": "standard",
                    "virtualAddresses": [
                        "192.168.57.100"
                    ],
                    "virtualPort": 443,
                    "iRules": [{
                        "use": "rule_sni_routing"
                    }],
                    "persistenceMethods": [{
                        "bigip": "/Common/ssl"
                    }]
                },
                "rule_sni_routing": {
                    "class": "iRule",
                    "iRule": {
                        "base64": ""
                    }
                }
            }
        }
    }
}