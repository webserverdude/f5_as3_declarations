{
    "$schema": "https://raw.githubusercontent.com/F5Networks/f5-appsvcs-extension/main/schema/latest/as3-schema.json",
    "class": "AS3",
    "action": "deploy",
    "persist": true,
    "declaration": {
        "class": "ADC",
        "schemaVersion": "3.0.0",
        "bados": {
            "class":"Tenant",
            "bados_service": {
                "class": "Application",
                "service_http": {
                    "class": "Service_HTTP",
                    "virtualPort": 80,
                    "virtualAddresses": [
                        "192.168.57.82"
                    ],
                    "pool": {
                        "use": "ltm_demo_pool"
                    },
                    "profileHTTP": {
                        "use": "pr_http_trust_xff"
                    },
                    "policyWAF": {
                        "use": "waf_profile"
                    },
                    "profileDOS": {
                        "use": "bados_profile"
                    },
                    "securityLogProfiles": [
                        {"bigip": "/Common/Log all requests"},
                        {"bigip": "/Common/local-dos"}
                    ],
                    "iRules": [
                        {"use": "bados_xff_insert_iRule"}
                    ]
                },
                "ltm_demo_pool": {
                    "class": "Pool",
                    "loadBalancingMode": "round-robin",
                    "members": [
                        {
                            "servicePort": 8000,
                            "serverAddresses": [
                                "10.0.2.71",
                                "10.0.2.72",
                                "10.0.2.73",
                                "10.0.2.74"
                            ],  
                            "shareNodes": true
                        }
                    ],
                    "monitors": ["http"]
                },
                "pr_http_trust_xff": {
                    "class": "HTTP_Profile",
                    "trustXFF": true
                },
                "bados_profile": {
                    "class": "DOS_Profile",
                    "application": {
                        "heavyURLProtection": {
                            "automaticDetectionEnabled": true
                        },
                        "stressBasedDetection": {
                            "operationMode": "blocking",
                            "thresholdsMode": "automatic",
                            "badActor": {
                                "detectionEnabled": true,
                                "useTlsPatternsForHostIdentification": true,
                                "signatureDetectionEnabled": true,
                                "tlsSignaturesEnabled": true,
                                "mitigationMode": "standard"
                            }
                        }
                    }
                },
                "waf_profile": {
                    "class": "WAF_Policy",
                    "url": "https://raw.githubusercontent.com/webserverdude/f5_declarative_waf/refs/heads/main/policies/base-policy.json",
                    "ignoreChanges": false
                },
                "bados_xff_insert_iRule": {
                    "class": "iRule",
                    "iRule": {
                        "base64": ""
                    }
                },
                "good_ips_datagroup": {
                    "class": "Data_Group",
                    "storageType": "internal",
                    "keyDataType": "ip",
                    "records": [
                        {
                            "key": "192.168.57.10/32"
                        },
                        {
                            "key": "192.168.57.11/32"
                        },
                        {
                            "key": "192.168.57.1/32"
                        }
                    ]
                },
                "bad_ips_datagroup": {
                    "class": "Data_Group",
                    "storageType": "internal",
                    "keyDataType": "ip",
                    "records": [
                        {
                            "key": "192.168.57.12/32"
                        },
                        {
                            "key": "192.168.57.13/32"
                        },
                        {
                            "key": "192.168.57.14/32"
                        }
                    ]
                }
            }
        }
    }
}